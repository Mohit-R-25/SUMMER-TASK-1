<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="simple_robot">

  <xacro:include filename="$(find my_robot_description)/urdf/gazebo.xacro"/>

  <link name="world"/>

  <!-- Chassis -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.55"/>
      <geometry>
        <box size="1 2 0.5"/>
      </geometry>

      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.55"/>
      <geometry>
        <box size="1 2 0.5"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia
      ixx="3.54"
      ixy="0.0"
      ixz="0.0"
      iyy="1.04"
      iyz="0.0"
      izz="4.17"/>
    </inertial>
  </link>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <!-- Top Left Wheel -->
  <link name="topleftwheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <mass value="1.0"/>
      <inertia
      ixx="0.006"
      ixy="0.0"
      ixz="0.0"
      iyy="0.006"
      iyz="0.0"
      izz="0.011"/>
    </inertial>

  </link>

  <joint name="topleftwheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="topleftwheel_link"/>
    <origin xyz="0.5 0.85 0.15"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- Top Right Wheel -->
  <link name="toprightwheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <mass value="1.0"/>
      <inertia
      ixx="0.006"
      ixy="0.0"
      ixz="0.0"
      iyy="0.006"
      iyz="0.0"
      izz="0.011"/>
    </inertial>
  </link>

  <joint name="toprightwheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="toprightwheel_link"/>
    <origin xyz="-0.5 0.85 0.15"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- Bottom Left Wheel -->
  <link name="bottomleftwheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <mass value="1.0"/>
      <inertia
      ixx="0.006"
      ixy="0.0"
      ixz="0.0"
      iyy="0.006"
      iyz="0.0"
      izz="0.011"/>
    </inertial>
  </link>

  <joint name="bottomleftwheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="bottomleftwheel_link"/>
    <origin xyz="0.5 -0.85 0.15"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- Bottom Right Wheel -->
  <link name="bottomrightwheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <cylinder radius="0.15" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <mass value="1.0"/>
      <inertia
      ixx="0.006"
      ixy="0.0"
      ixz="0.0"
      iyy="0.006"
      iyz="0.0"
      izz="0.011"/>
    </inertial>
  </link>

  <joint name="bottomrightwheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="bottomrightwheel_link"/>
    <origin xyz="-0.5 -0.85 0.15"/>
    <axis xyz="1 0 0"/>
  </joint>

</robot>